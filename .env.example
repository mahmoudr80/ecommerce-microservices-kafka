# Database Configuration
DB_USER=admin
DB_PASSWORD=password
DB_NAME=hotel_booking

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Kafka Configuration
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=hotel-booking-app

# Payment Configuration
# PAYMENT_MODE: success | fail | random (default)
# success: All payments will succeed
# fail: All payments will fail
# random: 90% success rate (default)
PAYMENT_MODE=random

# Environment
NODE_ENV=development

# Service URLs (for Docker Compose)
USER_SERVICE_URL=http://user-service:3001
HOTEL_SERVICE_URL=http://hotel-service:3002
ROOM_SERVICE_URL=http://room-service:3003
BOOKING_SERVICE_URL=http://booking-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006
REVIEW_SERVICE_URL=http://review-service:3007
